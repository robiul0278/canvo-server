# App
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/canvo

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@example.com

# NextAuth (MUST match frontend NEXTAUTH_SECRET)
NEXTAUTH_SECRET=your-super-secret-nextauth-key-here

# SSLCommerz
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASS=your_store_pass
SSLCOMMERZ_IS_LIVE=false

# Cloudinary (required on Vercel — local uploads won't persist)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
